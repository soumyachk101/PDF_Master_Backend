# Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=4000
NODE_ENV=production

# CORS Configuration
FRONTEND_URL=https://www.pdfkit.fun

# File Processing
MAX_FILE_SIZE_MB=100
TEMP_FILE_TTL_MINUTES=30

# Optional: Translation API (if needed)
TRANSLATE_API_KEY=

# Optional: Puppeteer executable path (Railway uses /run/current-system/sw/bin/chromium)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Optional: Allow all CORS origins (useful for testing, disable in production)
# ALLOW_ALL_CORS=false
